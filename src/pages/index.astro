---
// Dev PDF preview wrapper. Under `astro dev`, `/` shows the live-rendered resume
// PDF (served on demand by the `pdf-preview` middleware in astro.config.mjs)
// instead of the HTML — so what you iterate on is the actual print output. The
// resume HTML itself lives at /raw, which astro-pdf renders to resume.pdf for
// the build. In a static build this page is a harmless landing page that embeds
// the generated resume.pdf.
//
// A content edit broadcasts a full reload (see astro.config.ts), which re-fetches
// this page and thus re-requests the iframe. But Chrome's embedded PDF viewer
// caches its rendered document by URL and reuses it on a same-URL reload — even
// with the middleware's `Cache-Control: no-store` — so the preview would show
// stale output. Appending a per-load token makes each reload a distinct URL,
// forcing the viewer to render afresh. `import.meta.env.DEV` builds embed the
// static resume.pdf with no token. The middleware keys off the pathname, so the
// query string is ignored on the server side.
const pdfSrc = import.meta.env.DEV ? `/resume.pdf?t=${Date.now()}` : "/resume.pdf";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Résumé — PDF preview</title>
    <style>
      html,
      body {
        margin: 0;
        height: 100%;
        background: #525659; /* neutral gray, like a PDF viewer's chrome */
      }
      iframe {
        display: block;
        border: 0;
        width: 100%;
        height: 100vh;
      }
    </style>
  </head>
  <body>
    <iframe src={pdfSrc} title="Résumé PDF preview"></iframe>
  </body>
</html>
