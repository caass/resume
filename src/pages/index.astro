---
import { PHONE_NUMBER, EMAIL_ADDRESS } from "astro:env/server";

import Layout from "../layouts/Layout.astro";

import Skill from "../components/Skill.astro";
import Position from "../components/Position.astro";
import Section from "../components/Section.astro";
import IconLink from "../components/IconLink.astro";
import ContactLink from "../components/ContactLink.astro";
import Org from "../components/Org.astro";

import "@fontsource/atkinson-hyperlegible";
---

<Layout>
    <header>
        <h1>Cass Fridkin</h1>
        <address>
            <IconLink href="https://linkedin.com/in/caass" icon="linkedin">
                caass
            </IconLink>
            <IconLink href="https://github.com/caass" icon="github">
                caass
            </IconLink>
            <ContactLink
                phoneNumber={PHONE_NUMBER}
                emailAddress={EMAIL_ADDRESS}
            />
        </address>
    </header>
    <main>
        <Section title="Experience">
            <Org
                name="Trace Machina"
                from={new Date(2024, 4)}
                to={new Date(2024, 9)}
            >
                <Position role="Software Developer">
                    <li>
                        Mentored junior developers to develop in-house expertise
                    </li>
                    <li>
                        Designed and contributed documentation written with Qwik
                        and Astro
                    </li>
                    <li>
                        Drove implementation of major gRPC APIs in asynchronous
                        Rust codebase
                    </li>
                </Position>
            </Org>
            <Org
                name="Redjack"
                from={new Date(2023, 3)}
                to={new Date(2023, 11)}
            >
                <Position role="Senior Rust Engineer">
                    <li>
                        Re-architected final stage of multi-step data pipeline
                        to highlight action items
                    </li>
                    <li>
                        Refined serialized data format to save bandwidth during
                        transmission
                    </li>
                    <li>
                        Identified and removed bottlenecks in asynchronous
                        Rust/Tokio code
                    </li>
                </Position>
            </Org>
            <Org
                name="Cloudflare"
                from={new Date(2021, 1)}
                to={new Date(2023, 1)}
            >
                <Position role="Systems Engineer, Workers Experiences">
                    <li>
                        Drafted and published <IconLink
                            right
                            icon="square-arrow-out-up-right"
                            href="https://developers.cloudflare.com/workers/wrangler/migration/v1-to-v2/eject-webpack/"
                            target="_blank">docs</IconLink
                        > and <IconLink
                            right
                            icon="square-arrow-out-up-right"
                            href="https://blog.cloudflare.com/deprecating-wrangler-v1/"
                            target="_blank">blog post</IconLink
                        > on major product upgrade
                    </li>
                    <li>
                        Took on a mentorship role to both internal and external
                        contributors
                    </li>
                    <li>
                        Designed and built out bespoke build infrastructure for
                        multiple projects
                    </li>
                </Position>
                <Position role="Systems Engineer, Developer Productivity">
                    <li>
                        Communicated implementation details in legacy codebase
                        during software rewrite
                    </li>
                    <li>
                        Wrote and executed on design, product requirements, and
                        specification documents
                    </li>
                    <li>
                        Contributed productively web, API, and low-level systems
                        codebases
                    </li>
                </Position>
            </Org>
            <Org name="Cheff" from={new Date(2020, 2)} to={new Date(2020, 5)}>
                <Position role="Frontend Engineer">
                    <li>
                        Refactored existing React/Typescript codebase to adapt
                        to client needs
                    </li>
                    <li>
                        Iterated quickly and effectively on product requirement
                        updates
                    </li>
                    <li>
                        Implemented features across Amazon Web Services backend
                        and UI
                    </li>
                </Position>
            </Org>
        </Section>
        <Section title="Education">
            <Org
                name="Georgia Institute of Technology"
                from={new Date(2017, 7)}
                to={new Date(2019, 4)}
            >
                <Position>
                    <li>
                        Led both Visualization and Platform teams in the Big
                        Data Club
                    </li>
                    <li>
                        Pioneered infrastructure partnership between Georgia
                        Tech and Google Cloud
                    </li>
                </Position>
            </Org>
        </Section>
        <Section title="Research">
            <Org
                name="Georgia Emerging Infections Program"
                from={new Date(2017, 5)}
                to={new Date(2018, 3)}
            >
                <Position>
                    <li>
                        Identified healthcare facilities with statistically
                        significant infection rates
                    </li>
                    <li>
                        Cleaned, merged, analyzed, and visualized data across
                        multiple domains
                    </li>
                    <li>
                        Presented findings clearly and comprehensively as
                        closing speaker at SHEA 2018
                    </li>
                    <li>
                        Published in <em class="italic"
                            >Clinical Infectious Diseases</em
                        > (<IconLink
                            right
                            icon="square-arrow-out-up-right"
                            href="https://doi.org/10.1093/cid/ciz154"
                            target="_blank"
                        >
                            https://doi.org/10.1093/cid/ciz154
                        </IconLink>)
                    </li>
                </Position>
            </Org>
        </Section>
        <Section title="Skills" class="skills">
            <Skill category="Languages">
                Typescript, JavaScript, CSS & Sass, Rust, Go, Markdown
            </Skill>
            <Skill category="Tools">
                JSX, React/Next, Qwik, Astro, Vite/Rollup/Webpack
            </Skill>
            <Skill category="Concepts">
                Serverless paradigms, reactivity models, building & bundling,
                UI/UX
            </Skill>
        </Section>
    </main>
</Layout>

<style>
    address {
        display: flex;
        flex-flow: row nowrap;
        gap: 1rem;
    }

    h1 {
        margin: 0;
        font-weight: normal;
    }

    em.italic {
        font-style: italic;
    }

    .skills {
        display: grid;
        grid-template-columns:
            [category-start] min-content [category-end
            items-start] 1fr [items-end];
    }
</style>
