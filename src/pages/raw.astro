---
import { PHONE_NUMBER, EMAIL_ADDRESS } from "astro:env/server";
import { getCollection } from "astro:content";

import Layout from "../layouts/Layout.astro";

import Skill from "../components/Skill.astro";
import Position from "../components/Position.astro";
import Section from "../components/Section.astro";
import IconLink from "../components/IconLink.astro";
import ContactLink from "../components/ContactLink.astro";
import Org from "../components/Org.astro";

import "@fontsource/atkinson-hyperlegible";

const allPositions = await getCollection("positions");
const allSkills = await getCollection("skills");

// Orgs (and the positions within them) are grouped in the data itself; here we
// just split by section and order orgs most-recent-first.
const sectionOrder = ["experience", "research", "education"] as const;

const sections = sectionOrder.map((sectionId) => ({
  title: sectionId.charAt(0).toUpperCase() + sectionId.slice(1),
  orgs: allPositions
    .map((entry) => entry.data)
    .filter((data) => data.section === sectionId)
    .sort((a, b) => b.from.getTime() - a.from.getTime()),
}));
---

<Layout>
  <header>
    <h1>Cass Fridkin</h1>
    <address>
      <IconLink href="https://linkedin.com/in/caass" icon="linkedin">
        caass
      </IconLink>
      <IconLink href="https://github.com/caass" icon="github"> caass </IconLink>
      <ContactLink phoneNumber={PHONE_NUMBER} emailAddress={EMAIL_ADDRESS} />
    </address>
  </header>
  <main>
    {
      sections.map((section) => (
        <Section title={section.title}>
          {section.orgs.map((org) => (
            <Org name={org.org} from={org.from} to={org.to}>
              {org.positions.map((position) => (
                <Position role={position.role} bullets={position.bullets} />
              ))}
            </Org>
          ))}
        </Section>
      ))
    }
    <Section title="Skills" class="skills">
      {
        allSkills.map((skill) => (
          <Skill category={skill.data.category}>
            {skill.data.items.join(", ")}
          </Skill>
        ))
      }
    </Section>
  </main>
</Layout>

<style>
  address {
    display: flex;
    flex-flow: row nowrap;
    gap: 1rem;
  }

  h1 {
    margin: 0;
    font-weight: normal;
  }

  .skills {
    display: grid;
    grid-template-columns:
      [category-start] min-content [category-end
      items-start] 1fr [items-end];
  }
</style>
