---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"section"> {
  title: string;
}

const { title, ...props } = Astro.props;
---

<section class="outer">
  <header>
    <h2>{title}</h2>
    <hr />
  </header>
  <section {...props}>
    <slot />
  </section>
</section>

<style>
  section.outer {
    display: flex;
    flex-direction: column;
  }

  h2 {
    margin-top: 0.2rem;
    margin-bottom: 0;
    padding-bottom: 0;
    font-weight: normal;
  }

  hr {
    margin-top: 0.1rem;
    margin-bottom: 0.1rem;
  }
</style>
