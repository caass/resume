---
import ArrowLink from "./ArrowLink.astro";

type Segment = string | { text: string; href?: string; em?: boolean };
type Bullet = string | Segment[];

interface Props {
  role?: string;
  bullets: Bullet[];
}

const { role, bullets } = Astro.props;

const segmentsOf = (bullet: Bullet): Segment[] =>
  typeof bullet === "string" ? [bullet] : bullet;
---

<section>
  {role !== undefined ? <h4>{role}</h4> : null}
  <ul>
    {
      bullets.map((bullet) => (
        <li>
          {segmentsOf(bullet).map((seg) => {
            if (typeof seg === "string") return seg;
            const text = seg.em ? <em>{seg.text}</em> : seg.text;
            return seg.href !== undefined ? (
              <ArrowLink href={seg.href}>{text}</ArrowLink>
            ) : (
              text
            );
          })}
        </li>
      ))
    }
  </ul>
</section>

<style>
  h4 {
    margin: 0;
    font-style: italic;
    font-weight: normal;
  }
  ul {
    margin: 0;
  }
</style>
