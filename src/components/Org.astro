---
const fullFormatter = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "short",
  timeZone: "UTC",
});
const monthFormatter = new Intl.DateTimeFormat("en-US", {
  month: "short",
  timeZone: "UTC",
});

const formatTimeFrame = ({
  from,
  to,
}: {
  from: Date;
  to: Date | "Present";
}) => {
  const toDate = to instanceof Date ? to : new Date();
  const sameYear = from.getUTCFullYear() === toDate.getUTCFullYear();

  const fromStr = sameYear
    ? monthFormatter.format(from)
    : fullFormatter.format(from);
  const toStr = to instanceof Date ? fullFormatter.format(to) : to;

  return `${fromStr} – ${toStr}`;
};

type Props = {
  name: string;
  from: Date;
  to: Date | "Present";
};

const { name, from, to } = Astro.props;
---

<section>
  <header>
    <h3>
      <span>{name}</span>
      <span>{formatTimeFrame({ from, to })}</span>
    </h3>
  </header>
  <section>
    <slot />
  </section>
</section>

<style>
  h3 {
    margin: 0;
    display: flex;
    flex-flow: row nowrap;
    justify-content: space-between;
    font-weight: normal;
  }

  ul {
    margin-top: 0;
    margin-bottom: 0.75rem;
  }
</style>
